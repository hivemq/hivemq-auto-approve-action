{
  "name": "hivemq-auto-approve-action",
  "version": "1.0.0",
  "private": true,
  "description": "Auto-approve narrow release PRs based on team membership and a file/line allowlist.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --license licenses.txt",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "all": "npm run typecheck && npm run test && npm run build"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.44.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
