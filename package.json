{
  "name": "hivemq-auto-approve-action",
  "version": "1.0.0",
  "private": true,
  "description": "Auto-approve narrow release PRs based on team membership and a file/line allowlist.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --license licenses.txt",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "all": "npm run typecheck && npm run test && npm run build"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vercel/ncc": "^0.44.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
